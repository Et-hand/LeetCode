1480. Running Sum of 1d Array
class Solution:
    def runningSum(self, nums: List[int]) -> List[int]:
        sum_ans = []
        total = 0
        for i in range(0, len(nums)):
            total += nums[i]
            sum_ans.append(total)
        return sum_ans
