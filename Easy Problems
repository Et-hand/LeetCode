383. Ransom Note
class Solution:
    def canConstruct(self, ransomNote: str, magazine: str) -> bool:
        ransomNoteFreq = {}
        magazineFreq = {}
        for i in ransomNote:
            ransomNoteFreq[i] = ransomNoteFreq.get(i, 0) + 1
        for i in magazine:
            magazineFreq[i] = magazineFreq.get(i, 0) + 1
        if (set(ransomNoteFreq.keys()) - set(magazineFreq.keys()) != set()):
            return False
        for key, value in ransomNoteFreq.items():
            if (value > magazineFreq[key]):
                return False
        return True
