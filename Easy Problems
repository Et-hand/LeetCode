876. Middle of The Linked List #Optimal Solution
class Solution:
    def middleNode(self, head: Optional[ListNode]) -> Optional[ListNode]:
        fast = head
        slow = head
        while (fast and fast.next):
            fast = fast.next.next
            slow = slow.next
        return slow
#Tortise and Hare Solution, fast goes through the entire list twice as fast as slow, so returning slow once fast has traversed keeps it at O(n) time.
