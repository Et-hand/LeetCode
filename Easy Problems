26. Remove Duplicates from a Sorted Array
class Solution:
    def removeDuplicates(self, nums: List[int]) -> int:
        unique = 0
        to_check = unique + 1
        while (to_check < len(nums)):
            if nums[unique] == nums[to_check]:
                nums.pop(to_check)
                to_check -= 1
            else:
                unique += 1
            to_check = unique + 1
        return len(nums)
